    class Retrieval,HitCount,RAGTrigger,RAGFail,ScoreCheck,ZeroHitCheck decisionStyle
    class Path1,ReadFiles,ForceRAG,AlsoRAG,RunRAG,Degrade,UseText,DynClass,NotFound,ReuseCache ragStyle
    class In,Done startEndStyle
